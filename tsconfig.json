{
  "version": "6.0",
  "compilerOptions": {
    "sourceMap": false,
    "noImplicitAny": true,
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "target": "es2018",
    "experimentalDecorators": true,
    "rootDir": "./src",
    "outDir": "./lib",
    "declaration": true,
    "strictNullChecks": false,
    "strictFunctionTypes": true
  },
  "compileOnSave": false
}